      "name": "Orders",
      "item": [
        {
          "name": "Create Orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Parse the JSON response\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "// 2. Check if the request was successful\r",
                  "if (pm.response.code === 200 || pm.response.code === 201) {\r",
                  "    \r",
                  "    // 3. Look directly for _id (no .data wrapper needed!)\r",
                  "    if (json._id) {\r",
                  "        pm.environment.set(\"orderId\", json._id);\r",
                  "        console.log(\"Successfully saved orderId:\", json._id); \r",
                  "    } else {\r",
                  "        console.log(\"Could not find _id in the response.\");\r",
                  "    }\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const required = [\"retailerId\", \"batchId\", \"produceId\"];\r",
                  "const missing = required.filter(k => !pm.environment.get(k));\r",
                  "\r",
                  "if (missing.length) {\r",
                  "  throw new Error(\r",
                  "    `Missing required environment variable(s): ${missing.join(\", \")}. ` +\r",
                  "    `Set them in the active environment before creating an order.`\r",
                  "  );\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"retailerId\": \"{{retailerId}}\",\r\n  \"batchId\": \"{{batchId}}\",\r\n  \"produceId\": \"{{produceId}}\",\r\n  \"quantity\": 50,\r\n  \"deliveryAddress\": \"123 Market Street, Lagos\",\r\n  \"status\": \"pending\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "orders"
