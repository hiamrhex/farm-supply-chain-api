              "raw": "{\r\n  \"farmerId\": \"{{farmerId}}\",\r\n  \"produceId\": \"{{produceId}}\",\r\n  \"quantity\": 1000,\r\n  \"harvestDate\": \"2026-03-25\",\r\n  \"status\": \"harvested\"\r\n}",
