            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Keep existing extraction (required)",
                  "pm.environment.set(\"farmerId\", pm.response.json().data._id);",
                  "",
                  "// Basic response tests",
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"Response body has success=true\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"success\", true);",
                  "});",
                  "",
                  "pm.test(\"Response has data object with expected fields\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"data\");",
                  "    pm.expect(json.data).to.be.an(\"object\");",
                  "",
                  "    pm.expect(json.data).to.have.property(\"_id\");",
                  "    pm.expect(json.data._id).to.be.a(\"string\").and.not.be.empty;",
                  "",
                  "    pm.expect(json.data).to.have.property(\"name\");",
                  "    pm.expect(json.data.name).to.be.a(\"string\");",
                  "",
                  "    pm.expect(json.data).to.have.property(\"location\");",
                  "    pm.expect(json.data.location).to.be.a(\"string\");",
                  "",
                  "    pm.expect(json.data).to.have.property(\"farmSize\");",
                  "    pm.expect(json.data.farmSize).to.be.a(\"number\");",
                  "",
                  "    pm.expect(json.data).to.have.property(\"produceTypes\");",
                  "    pm.expect(json.data.produceTypes).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test(\"createdAt/updatedAt are ISO timestamps (if present)\", function () {",
                  "    const { data } = pm.response.json();",
                  "    if (data.createdAt) pm.expect(new Date(data.createdAt).toString()).to.not.equal(\"Invalid Date\");",
                  "    if (data.updatedAt) pm.expect(new Date(data.updatedAt).toString()).to.not.equal(\"Invalid Date\");",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
